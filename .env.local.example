# =====================================================
# Plantilla de variables de entorno — MedAdvisor AI
# =====================================================
# Copia este archivo a `.env.local` y rellena los valores.
# .env.local SÍ está en .gitignore (NO se sube a GitHub).
# Este .env.local.example SÍ se sube (es la plantilla).
#
# Para obtener los valores, consulta el README.md ("Aprovisionamiento de Azure")
# o usa los secretos guardados en tu Key Vault:
#
#   KV=kv-medadvisor-2026
#   az keyvault secret show --vault-name $KV --name aoai-key --query value -o tsv
# =====================================================

# --- Azure OpenAI (chat + embeddings) ---
AZURE_OPENAI_ENDPOINT=https://<tu-cuenta>.cognitiveservices.azure.com/
AZURE_OPENAI_API_KEY=<tu-key>
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_DEPLOYMENT_CHAT=gpt-4o
AZURE_OPENAI_DEPLOYMENT_EMBED=text-embedding-3-large

# --- Document Intelligence ---
AZURE_DOCINTEL_ENDPOINT=https://<tu-recurso>.cognitiveservices.azure.com/
AZURE_DOCINTEL_API_KEY=<tu-key>

# --- AI Search (Free tier OK) ---
AZURE_SEARCH_ENDPOINT=https://<tu-search>.search.windows.net
AZURE_SEARCH_API_KEY=<tu-admin-key>
AZURE_SEARCH_INDEX_HOSPITALES=hospitales

# --- Blob Storage ---
# IMPORTANTE: la connection string contiene `;`. Encierra el valor entre comillas dobles:
#   AZURE_STORAGE_CONNECTION_STRING="DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;..."
AZURE_STORAGE_CONNECTION_STRING="<tu-connection-string-completa>"
AZURE_STORAGE_CONTAINER_POLIZAS=polizas

# --- Azure Speech (TTS Andrea Neural) ---
AZURE_SPEECH_KEY=<tu-key>
AZURE_SPEECH_REGION=eastus
AZURE_SPEECH_VOICE_ES=es-EC-AndreaNeural
AZURE_SPEECH_VOICE_EN=en-US-JennyNeural

# --- Key Vault (referencia, no se usa en runtime; los valores se copian arriba) ---
AZURE_KEY_VAULT_URI=https://<tu-vault>.vault.azure.net/

# --- Token admin ---
# Protege /api/admin/seed de uso público.
# Genéralo con: openssl rand -hex 32  (o: python -c "import secrets; print(secrets.token_hex(32))")
# Sin este token, /api/admin/seed devuelve 401.
ADMIN_TOKEN=<genera-un-string-largo-y-aleatorio>
